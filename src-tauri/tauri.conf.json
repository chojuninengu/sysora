{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sysora",
  "version": "0.1.0",
  "identifier": "com.chojuninengu.sysora",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Sysora",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 580,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform system monitor & manager",
    "longDescription": "Sysora lets you monitor memory, CPU, disk, and battery health. Kill hungry processes, manage installed apps, scan disk usage, and inspect full system specs — all from a modern dashboard with a tray icon.",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
